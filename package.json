{
  "publisher": "danieledep",
  "name": "vscode-color-provider-everywhere",
  "displayName": "Color Provider Everywhere",
  "version": "0.0.1",
  "description": "Show the native color picker in every file — even where no language extension provides one — without ever creating duplicate decorators.",
  "author": "danieledep <dan.depietri@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/danieledep/vscode-color-provider-everywhere#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/danieledep/vscode-color-provider-everywhere"
  },
  "bugs": {
    "url": "https://github.com/danieledep/vscode-color-provider-everywhere/issues"
  },
  "keywords": [
    "color",
    "color picker",
    "color decorator",
    "colorProvider"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/index.cjs",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "README.md",
    "dist/*",
    "res/icon.png"
  ],
  "engines": {
    "vscode": "^1.97.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Color Provider Everywhere",
      "properties": {
        "colorProviderEverywhere.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the fallback color picker in files where no other provider supplies colors."
        }
      }
    }
  },
  "scripts": {
    "dev": "tsdown src/index.ts --external vscode --format cjs --watch --sourcemap",
    "build": "tsdown src/index.ts --external vscode --format cjs",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "^3.7.1",
    "tsdown": "^0.19.0-beta.3",
    "typescript": "^5.9.3"
  }
}